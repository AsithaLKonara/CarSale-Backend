# 🏎️ UltraDrive Backend - Environment Variables Template
# Copy this file to '.env' and populate with your own credentials.

# 🌐 Network & Server Configurations
PORT=5000
NODE_ENV=development # Options: development, production, test

# 🗄️ Relational Database (PostgreSQL with Prisma)
# Replace credentials below with your PostgreSQL server credentials
DATABASE_URL="postgresql://asithalakmal@localhost:5432/ultradrive?schema=public"

# 🔑 Cryptography & Session Tokens (JWT)
# IMPORTANT: Replace these with strong, cryptographically secure random values in production!
JWT_SECRET="super_secure_ultradrive_jwt_core_access_secret_phrase_change_me"
JWT_REFRESH_SECRET="super_secure_ultradrive_jwt_core_refresh_secret_phrase_change_me"

# ⏱️ Authentication Token Durations
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ⚡ Performance & Caching (Redis)
# Required for real-time rates, rate-limiting synchronizations, and caching.
REDIS_URL="redis://localhost:6379"

# 🖼️ Media Storage & Delivery (Cloudinary Integration)
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL="cloudinary://your_api_key:your_api_secret@your_cloud_name"

# 📧 Email Dispatching (Resend Integration API)
RESEND_API_KEY="re_your_api_key_here"
